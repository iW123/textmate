#!/bin/sh
set -e

error() {
    echo "$1"
    exit 1
}

for dep in brew ninja ragel capnp multimarkdown; do
    command -v "$dep" >/dev/null || error "$dep not found"
done

PREFIX="$(brew --prefix)"

cat > local.rave <<EOF
add FLAGS "-I${PREFIX}/include"
add LN_FLAGS "-L${PREFIX}/lib"
EOF

exec bin/rave -crelease -tTextMate
