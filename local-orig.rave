# Local build only

add IB_FLAGS "--minimum-deployment-target=${APP_MIN_OS}"

capture BREW_PREFIX "brew --prefix"

add FLAGS "-I${BREW_PREFIX}/include"
add LN_FLAGS "-L${BREW_PREFIX}/lib"

config debug {
    capture BUILD_ARCH "uname -m"
    add LN_FLAGS "-L${BREW_PREFIX}/lib"
}

config release {
    arch "arm64" "x86_64" {
        add FLAGS "-target macos-${arch}"
        add LN_FLAGS "-target macos-${arch}"
        add LN_FLAGS "-L${BREW_PREFIX}/lib"
    }
}
